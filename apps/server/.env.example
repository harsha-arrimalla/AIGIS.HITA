# === REQUIRED ===

# AI APIs
ANTHROPIC_API_KEY=sk-ant-...        # Main Hita Brain (Claude)
GEMINI_API_KEY=...                  # Intent classification + voice (Gemini Flash)

# Database
DATABASE_URL=postgresql://user:password@host:5432/hita?schema=public

# Auth
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...       # Server-only, never expose to client

# Maps & Location
GOOGLE_MAPS_API_KEY=...             # Places + geocoding
TOMTOM_API_KEY=...                  # Transit routing

# Weather
OPENWEATHER_API_KEY=...

# Payments
RAZORPAY_KEY_ID=...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# Communications
WHATSAPP_API_KEY=...                # Via Gupshup or Meta Cloud API
WHATSAPP_PHONE_NUMBER_ID=...
RESEND_API_KEY=re_...

# Cache
UPSTASH_REDIS_REST_URL=...
UPSTASH_REDIS_REST_TOKEN=...

# Server
PORT=3000
NODE_ENV=development                # development | staging | production
LOG_LEVEL=info                      # debug | info | warn | error

# Dev flags
SKIP_AUTH=true                      # Skip JWT verification in development

# === OPTIONAL ===
SENTRY_DSN=...                      # Error tracking
POSTHOG_API_KEY=...                 # Analytics
STRIPE_SECRET_KEY=sk_test_...       # International payments (v2.0+)
