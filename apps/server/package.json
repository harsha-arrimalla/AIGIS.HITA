{
  "name": "@hita/server",
  "version": "1.0.0",
  "description": "AI guardian companion backend — agents, orchestration, and conversational AI",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio"
  },
  "keywords": [
    "ai",
    "guardian",
    "travel",
    "safety"
  ],
  "author": "Harshavardhan Arrimalla",
  "license": "UNLICENSED",
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.104.1",
    "@upstash/redis": "^1.37.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-raw-body": "^5.0.0",
    "zod": "^4.3.6"
  }
}
