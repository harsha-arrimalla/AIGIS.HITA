# ─────────────────────────────────────────────────────────────────────────────
# Hita — Production Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file:  cp .env.production.example .env.production
# Fill in the values, then use with docker-compose or fly secrets.
#
# NEVER commit .env.production — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://hita.yourdomain.com,https://hita-web.fly.dev

# ── Supabase (Postgres + Auth) ───────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Prisma — same DB, direct connection string
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.your-project.supabase.co:5432/postgres

# ── AI Providers ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...

# ── External APIs ────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...
OPENWEATHER_API_KEY=
TOMTOM_API_KEY=

# ── Upstash Redis (rate limiting + caching) ──────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# ── Razorpay (payments) ─────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Web Frontend (passed as build args, not runtime secrets) ─────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_API_URL=https://hita-server.fly.dev
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_...
